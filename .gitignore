# gitignore for imx6ull_journey project root

# IDEs and editors
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
Thumbs.db

# Compilation artifacts
*.o
*.ko
*.so
*.a
*.bin
*.elf
*.dtb
*.dtbo
*.mod.c
*.mod
*.mod.o
.*.cmd

# Linux Kernel specific extra
.config
.config.old
vmlinux
System.map
Module.symvers
modules.order
.tmp_versions/

# Python (if any)
__pycache__/
*.pyc

# Local scripts/output
/output/
/build/
/tmp/
